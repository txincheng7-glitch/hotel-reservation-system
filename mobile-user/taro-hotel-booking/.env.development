# 配置文档参考 https://taro-docs.jd.com/docs/next/env-mode-config
# TARO_APP_ID="开发环境下的小程序 AppID"

# 后端接口地址（小程序端必须是完整 https/http 地址）
# 例如: TARO_APP_API_BASE_URL="https://api.example.com"
TARO_APP_API_BASE_URL="http://122.51.25.229:3000"

# 接口基础路径，后端文档为 /api
TARO_APP_API_PREFIX="/api"

# 是否强制使用本地 mock（1/true 表示启用 mock）
TARO_APP_USE_MOCK="0"
